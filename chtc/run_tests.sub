# HTCondor submit file for CHTC GPU test job.
#
# Submit from a CHTC access point (e.g. ap2001.chtc.wisc.edu) after:
#   1. pushing your Docker image to Docker Hub (or GHCR)
#   2. setting HF_TOKEN in your shell environment
#
# Usage:
#   condor_submit chtc/run_tests.sub
#
# After completion:
#   condor_history -limit 1 -af JobStatus ExitCode RemoteWallClockTime
#   python chtc/analyze_results.py logs/test.<cluster>.<process>

# ============================================================================
# Container — pulled from Docker Hub at job start; HTCondor caches it
# ============================================================================
container_image = docker://nevneal/remote_sam3:latest

# ============================================================================
# Executable + arguments
# ============================================================================
executable = chtc/run_tests.sh
# arguments: taxon_id  output_dir  limit
arguments  = 591507 test_output 1

# ============================================================================
# GPU Lab request — required for any GPU job at CHTC
# ============================================================================
+WantGPULab = true
+GPUJobLength = "short"

request_gpus = 1
request_cpus = 2
request_memory = 16GB
request_disk = 20GB

# Optional: pin to a minimum GPU memory (uncomment if SAM3 OOMs on small GPUs)
# gpus_minimum_memory = 16000

# (No staging requirement — container is pulled from Docker Hub.)

# ============================================================================
# Environment — pass HF_TOKEN from submit env so the gated SAM3 repo works
# ============================================================================
getenv = HF_TOKEN
# HF_HOME is set inside run_tests.sh using the runtime $PWD so the cache lands
# in the job's scratch dir and comes back via HTCondor's default output transfer.

# ============================================================================
# File transfer
# ============================================================================
should_transfer_files = YES
when_to_transfer_output = ON_EXIT

# Inputs: only the scripts; the SIF is referenced by container_image, not transferred here.
transfer_input_files = test_on_chtc.py, segmentation_pipeline.py, chtc/run_tests.sh

# Outputs: HTCondor automatically transfers everything created in the job's
# working directory, except large bind-mounted paths. We rely on that default
# so test_output/, test_results.json, and any logs come back.

# ============================================================================
# Log files — analyze_results.py reads these
# ============================================================================
log    = logs/test.$(Cluster).$(Process).log
output = logs/test.$(Cluster).$(Process).out
error  = logs/test.$(Cluster).$(Process).err

# Keep the job alive after Held so you can read the hold reason.
on_exit_hold = (ExitCode != 0)
on_exit_hold_reason = "Job exited non-zero — see *.err and test_results.json"

queue 1
